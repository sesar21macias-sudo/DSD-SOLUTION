# Agente de IA
# Proveedor: "gemini" (gratis) o "claude"; por defecto gemini si hay GEMINI_API_KEY
AGENT_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=
ANTHROPIC_API_KEY=
AGENT_MODEL=

# Google OAuth (Calendar + Drive) — fase 3
# Scopes necesarios: https://www.googleapis.com/auth/calendar
#                    https://www.googleapis.com/auth/drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Login de administrador
# Solo el creador (Sesar) tiene acceso con PIN 1234
# Cualquier nombre + PIN 1234 abre sesión admin
ADMIN_USER=*
ADMIN_PASS=1234
# Cadena aleatoria larga para firmar la cookie de sesión en producción.
SESSION_SECRET=
